# --- Neon Postgres ----------------------------------------------------------
# Pooled connection string from your Neon project. Use the "Pooled connection"
# string for application traffic; drizzle-kit will use the same URL.
DATABASE_URL=postgres://USER:PASSWORD@ep-XXX.eu-central-1.aws.neon.tech/neondb?sslmode=require

# --- Clerk ------------------------------------------------------------------
# From the Clerk dashboard → API Keys.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxx
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxx

# Webhook signing secret from the Clerk dashboard → Webhooks endpoint
# (point the endpoint at https://<your-domain>/api/clerk/webhook).
CLERK_WEBHOOK_SIGNING_SECRET=whsec_xxxxxxxxxxxxxxxxxxxx

# Clerk routing — keep in sync with src/app/sign-in and src/app/sign-up.
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# --- GitHub (researcher submission flow) ------------------------------------
# Required for automatic draft-PR creation on submission. If unset, the
# dashboard still accepts submissions and stores them in DB, but no PR is
# opened automatically — Content Lead handles publication manually.
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx
GITHUB_REPO_OWNER=ze-alenu
GITHUB_REPO_NAME=zealenu
GITHUB_DEFAULT_BRANCH=main

# --- Resend (Content Lead notifications) ------------------------------------
# Optional. If any of the three are unset, submissions still go through but
# Content Lead is not emailed automatically.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
EMAIL_FROM_ADDRESS="ZeAlenu <noreply@zealenu.example>"
CONTENT_LEAD_EMAIL=content@zealenu.example
