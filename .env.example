# --- Neon Postgres ----------------------------------------------------------
# Pooled connection string from your Neon project. Use the "Pooled connection"
# string for application traffic; drizzle-kit will use the same URL.
DATABASE_URL=postgres://USER:PASSWORD@ep-XXX.eu-central-1.aws.neon.tech/neondb?sslmode=require

# --- Clerk ------------------------------------------------------------------
# From the Clerk dashboard → API Keys.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxx
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxx

# Webhook signing secret from the Clerk dashboard → Webhooks endpoint
# (point the endpoint at https://<your-domain>/api/clerk/webhook).
CLERK_WEBHOOK_SIGNING_SECRET=whsec_xxxxxxxxxxxxxxxxxxxx

# Clerk routing — keep in sync with src/app/sign-in and src/app/sign-up.
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# --- GitHub (researcher submission flow) ------------------------------------
# Required for automatic draft-PR creation on submission. If unset, the
# dashboard still accepts submissions and stores them in DB, but no PR is
# opened automatically — Content Lead handles publication manually.
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx
GITHUB_REPO_OWNER=ze-alenu
GITHUB_REPO_NAME=zealenu
GITHUB_DEFAULT_BRANCH=main

# --- Resend (Content Lead notifications) ------------------------------------
# Optional. If any of the three are unset, submissions still go through but
# Content Lead is not emailed automatically.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
EMAIL_FROM_ADDRESS="ZeAlenu <noreply@zealenu.example>"
CONTENT_LEAD_EMAIL=content@zealenu.example

# --- Site URL ---------------------------------------------------------------
# Canonical production URL. Used by metadata, sitemap, robots, and JSON-LD.
# Vercel preview deploys override this with VERCEL_URL automatically.
NEXT_PUBLIC_SITE_URL=https://zealenu.org.il

# --- Plausible Analytics (optional) ----------------------------------------
# Set NEXT_PUBLIC_PLAUSIBLE_DOMAIN to the domain registered in Plausible to
# enable client-side page-view tracking. Leave unset for environments without
# analytics. NEXT_PUBLIC_PLAUSIBLE_SCRIPT_SRC points at a self-hosted Plausible
# Community Edition instance; defaults to the hosted plausible.io script.
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=zealenu.org.il
# NEXT_PUBLIC_PLAUSIBLE_SCRIPT_SRC=https://plausible.example.com/js/script.js

# --- Sentry (optional) ------------------------------------------------------
# DSN enables runtime error capture (frontend + serverless + edge). Without
# DSN the SDK is a no-op. Source-map upload only runs at build time when
# SENTRY_AUTH_TOKEN is present (set this in Vercel/CI, NOT in .env).
NEXT_PUBLIC_SENTRY_DSN=https://xxxxx@oXXXXXX.ingest.sentry.io/XXXXXX
SENTRY_ORG=zealenu
SENTRY_PROJECT=zealenu-web
# SENTRY_AUTH_TOKEN=sntrys_xxxxxxxxxxxxxxxxxxxx   # build-time only, do NOT commit
# NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1       # default: 0.1 in production, 1.0 elsewhere

# --- Smoke tests ------------------------------------------------------------
# Override the target for `pnpm smoke` (defaults to https://zealenu.org.il).
# SMOKE_BASE_URL=https://staging.zealenu.org.il
